struct Session  src/server.rs:32-37
```
/// A session managed by the server.
pub struct Session {
    pub id: String,
    pub user: String,
    created_at: u64,
}
```

impl Session  src/server.rs:39-51
```
impl Session {
    pub fn new(id: &str, user: &str) -> Self {
        Self {
            id: id.to_owned(),
            user: user.to_owned(),
            created_at: 0,
        }
    }

    pub fn age_seconds(&self, now: u64) -> u64 {
        now.saturating_sub(self.created_at)
    }
}
```

fn add_session  src/server.rs:67-69  (in Server)
```
pub fn add_session(&mut self, session: Session) {
        self.sessions.insert(session.id.clone(), session);
    }
```

fn remove_session  src/server.rs:71-73  (in Server)
```
pub fn remove_session(&mut self, id: &str) -> Option<Session> {
        self.sessions.remove(id)
    }
```

fn session_count  src/server.rs:75-77  (in Server)
```
pub fn session_count(&self) -> usize {
        self.sessions.len()
    }
```

fn find_user_sessions  src/server.rs:83-89  (in Server)
```
/// Find sessions belonging to a specific user.
    pub fn find_user_sessions(&self, user: &str) -> Vec<&Session> {
        self.sessions
            .values()
            .filter(|s| s.user == user)
            .collect()
    }
```

