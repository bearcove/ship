hooks {
    worktree_setup {
        pnpm-install {
            command "pnpm install"
        }
    }

    checks {
        codegen {
            command "cargo xtask codegen --check"
            glob ("**/*.rs")
        }

        typecheck {
            command "pnpm exec tsgo --noEmit"
            cwd frontend
            glob ("**/*.ts" "**/*.tsx")
        }

        tracey {
            command "tracey query validate"
            glob ("**/*.rs" "**/*.md")
        }

        capn {
            command "capn pre-push"
        }
    }
}
